{
  "name": "tokori-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser extension for language learners: local-first hover dictionary, YouTube subtitle mining, Anki export, and optional Tokori desktop/cloud sync.",
  "license": "MIT",
  "author": "Tokori",
  "homepage": "https://github.com/tokoriai/tokori-chrome-extension#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokoriai/tokori-chrome-extension.git"
  },
  "bugs": {
    "url": "https://github.com/tokoriai/tokori-chrome-extension/issues"
  },
  "keywords": [
    "chrome-extension",
    "browser-extension",
    "language-learning",
    "dictionary",
    "anki",
    "sentence-mining",
    "youtube",
    "spaced-repetition",
    "manifest-v3"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:run"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.0.270",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "shadcn": "^4.8.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  }
}
